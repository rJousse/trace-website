rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Articles — lecture publique si publié, lecture+écriture complète pour l'admin
    match /articles/{id} {
      allow read: if resource.data.published == true || request.auth != null;
      allow write: if request.auth != null;
    }

    // Polls — lecture publique si publié, lecture+écriture complète pour l'admin
    match /polls/{id} {
      allow read: if resource.data.published == true || request.auth != null;
      allow write: if request.auth != null;
    }

    // Réponses — tout le monde peut créer, seul l'admin peut lire/supprimer
    match /responses/{id} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }
  }
}
