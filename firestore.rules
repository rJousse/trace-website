rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Articles — lecture publique (le filtre published==true est géré côté app)
    match /articles/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Polls — lecture publique, écriture admin, mise à jour compteurs publique
    match /polls/{id} {
      allow read: if true;
      allow create, delete: if request.auth != null;
      allow update: if request.auth != null ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCounts']);
    }

    // Réponses — tout le monde peut créer, seul l'admin peut lire/supprimer
    match /responses/{id} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }
  }
}
